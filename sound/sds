#!/bin/sh

###################################################################
# Script Name	: Set default sink (sds)
# Description	: Sets default sink to the provided one.
# Args		: $1 - sinkid or name
# Dependencies	: pactl
# Variables	:
# Author	: Mateusz Reszka
# Email		: mateusz@mateuszreszka.xyz
###################################################################

sink=$(pl | awk '{ print $2 }' | menu -i -l 6)
prev_sink=$(currsink)

[ -z "$sink" ] && exit 1
pactl set-default-sink $sink

to_move=$(pactl list sink-inputs short | awk -F ' ' '{print $1}')

#for i in "$to_move"; do
#    pactl move-sink-input $prev_sink $i
#done

notify-send "Sink changed!" "sound from '$prev_sink' redirected to '$sink'"
